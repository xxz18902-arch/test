    -- Enhanced Keybind
    function Library.Sections:Keybind(Data)
        Data = Data or {}
        
        local Keybind = {
            Section = self,
            Name = Data.Name or Data.name or "Keybind",
            Flag = Data.Flag or Data.flag or Library:NextFlag(),
            Default = Data.Default or Data.default or nil,
            Mode = Data.Mode or Data.mode or "Toggle",
            Callback = Data.Callback or Data.callback or function() end,
            Key = nil,
            Toggled = false,
            IsPicking = false
        }
        
        local Y = self.CurrentY
        
        -- Container
        local Container = DrawingProxy.new("Square", {
            Parent = self.Content,
            Position = UDim2New(0, 0, 0, Y),
            Size = UDim2New(1, 0, 0, 20),
            Color = Colors.Section,
            Filled = true,
            Transparency = 0,
            ZIndex = 58
        })
        
        -- Label
        local Label = DrawingProxy.new("Text", {
            Parent = Container,
            Position = UDim2New(0, 0, 0, 2),
            Size = 12,
            Color = Colors.TextActive,
            Text = Keybind.Name,
            Font = 1,
            Transparency = 1,
            ZIndex = 59
        })
        
        -- Key display
        local KeyBg = DrawingProxy.new("Image", {
            Parent = Container,
            Position = UDim2New(1, -60, 0, 0),
            Size = UDim2New(0, 50, 0, 18),
            Color = Colors.Border,
            Rounding = 4,
            Transparency = 1,
            Data = PixelData,
            ZIndex = 59
        })
        
        local KeyInside = DrawingProxy.new("Image", {
            Parent = KeyBg,
            Position = UDim2New(0, 1, 0, 1),
            Size = UDim2New(1, -2, 1, -2),
            Color = Colors.Element,
            Rounding = 4,
            Transparency = 1,
            Data = PixelData,
            ZIndex = 60
        })
        
        local KeyText = DrawingProxy.new("Text", {
            Parent = KeyInside,
            Position = UDim2New(0.5, 0, 0, 2),
            Size = 11,
            Color = Colors.TextActive,
            Text = "None",
            Font = 1,
            Center = true,
            Transparency = 1,
            ZIndex = 61
        })
        
        function Keybind:Set(KeyData)
            if type(KeyData) == "table" and KeyData.Key then
                self.Key = KeyData.Key
                self.Mode = KeyData.Mode or self.Mode
                
                local KeyName = tostring(self.Key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
                KeyText.Text = KeyName == "Backspace" and "None" or KeyName
                
                Library.Flags[self.Flag] = {
                    Key = self.Key,
                    Mode = self.Mode,
                    Toggled = self.Toggled
                }
            elseif type(KeyData) == "string" then
                self.Mode = KeyData
                Library.Flags[self.Flag] = {
                    Key = self.Key,
                    Mode = self.Mode,
                    Toggled = self.Toggled
                }
            end
            
            if self.Callback then
                Library:SafeCall(self.Callback, self.Toggled)
            end
        end
        
        function Keybind:Press(Bool)
            if self.Mode == "Toggle" then
                self.Toggled = not self.Toggled
            elseif self.Mode == "Hold" then
                self.Toggled = Bool
            elseif self.Mode == "Always" then
                self.Toggled = true
            end
            
            Library.Flags[self.Flag] = {
                Key = self.Key,
                Mode = self.Mode,
                Toggled = self.Toggled
            }
            
            if self.Callback then
                Library:SafeCall(self.Callback, self.Toggled)
            end
        end
        
        -- Click to set
        Library:Connect(UserInputService.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and self.Window.IsOpen then
                local MousePos = UserInputService:GetMouseLocation()
                local KeyPos = KeyBg.RealPosition
                local KeySize = KeyBg.RealSize
                
                if MousePos.X >= KeyPos.X and MousePos.X <= KeyPos.X + KeySize.X and
                   MousePos.Y >= KeyPos.Y and MousePos.Y <= KeyPos.Y + KeySize.Y then
                    if not Keybind.IsPicking then
                        Keybind.IsPicking = true
                        KeyText.Text = "..."
                        KeyText.Color = Colors.Accent
                        
                        local Connection
                        Connection = UserInputService.InputBegan:Connect(function(Input2)
                            if Input2.UserInputType == Enum.UserInputType.Keyboard then
                                Keybind:Set({Key = Input2.KeyCode, Mode = Keybind.Mode})
                            else
                                Keybind:Set({Key = Input2.UserInputType, Mode = Keybind.Mode})
                            end
                            KeyText.Color = Colors.TextActive
                            Keybind.IsPicking = false
                            Connection:Disconnect()
                        end)
                    end
                end
            end
            
            -- Key press detection
            if Keybind.Key and not Keybind.IsPicking then
                local InputKey = Input.KeyCode ~= Enum.KeyCode.Unknown and Input.KeyCode or Input.UserInputType
                if tostring(InputKey) == tostring(Keybind.Key) then
                    if Keybind.Mode == "Toggle" then
                        Keybind:Press()
                    elseif Keybind.Mode == "Hold" then
                        Keybind:Press(true)
                    end
                end
            end
        end)
        
        Library:Connect(UserInputService.InputEnded, function(Input)
            if Keybind.Key and Keybind.Mode == "Hold" then
                local InputKey = Input.KeyCode ~= Enum.KeyCode.Unknown and Input.KeyCode or Input.UserInputType
                if tostring(InputKey) == tostring(Keybind.Key) then
                    Keybind:Press(false)
                end
            end
        end)
        
        if Keybind.Default then
            Keybind:Set({Key = Keybind.Default, Mode = Keybind.Mode})
        end
        
        self.CurrentY = self.CurrentY + 25
        self.Height = self.Height + 25
        
        Library.SetFlags[Keybind.Flag] = function(Value)
            Keybind:Set(Value)
        end
        
        return Keybind
    end

