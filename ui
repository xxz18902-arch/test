        })
        
        -- Value display
        local ValueText = DrawingProxy.new("Text", {
            Parent = self.Content,
            Position = UDim2New(1, -50, 0, Y),
            Size = 12,
            Color = Colors.Accent,
            Text = tostring(Slider.Default) .. Slider.Suffix,
            Font = 1,
            Transparency = 1,
            ZIndex = 58
        })
        
        -- Slider track
        local Track = DrawingProxy.new("Image", {
            Parent = self.Content,
            Position = UDim2New(0, 0, 0, Y + 18),
            Size = UDim2New(1, 0, 0, 8),
            Color = Colors.Border,
            Rounding = 4,
            Transparency = 1,
            Data = PixelData,
            ZIndex = 59
        })
        
        local TrackInside = DrawingProxy.new("Image", {
            Parent = Track,
            Position = UDim2New(0, 1, 0, 1),
            Size = UDim2New(1, -2, 1, -2),
            Color = Colors.Element,
            Rounding = 4,
            Transparency = 1,
            Data = PixelData,
            ZIndex = 60
        })
        
        -- Fill
        local Fill = DrawingProxy.new("Image", {
            Parent = TrackInside,
            Position = UDim2New(0, 0, 0, 0),
            Size = UDim2New(0, 0, 1, 0),
            Color = Colors.Accent,
            Rounding = 4,
            Transparency = 1,
            Data = PixelData,
            ZIndex = 61
        })
        
        -- Dragger
        local Dragger = DrawingProxy.new("Image", {
            Parent = Track,
            Position = UDim2New(0, -4, 0, -2),
            Size = UDim2New(0, 10, 0, 12),
            Color = Colors.AccentLight,
            Rounding = 4,
            Transparency = 1,
            Data = PixelData,
            ZIndex = 62
        })
        
        function Slider:Set(Value)
            self.Value = MathClamp(Library:Round(Value, self.Decimals), self.Min, self.Max)
            Library.Flags[self.Flag] = self.Value
            
            local Percent = (self.Value - self.Min) / (self.Max - self.Min)
            
            TweenObject(Fill.Object, {Size = UDim2New(Percent, 0, 1, 0)}, 0.1, "Circular")
            TweenObject(Dragger.Object, {Position = UDim2New(Percent, -4, 0, -2)}, 0.1, "Circular")
            
            ValueText.Text = tostring(self.Value) .. self.Suffix
            
            if self.Callback then
                Library:SafeCall(self.Callback, self.Value)
            end
        end
        
        function Slider:Get()
            return self.Value
        end
        
        -- Input handling
        local function UpdateSlider(Input)
            local TrackPos = Track.RealPosition
            local TrackSize = Track.RealSize
            local RelativeX = MathClamp((Input.Position.X - TrackPos.X) / TrackSize.X, 0, 1)
            local Value = self.Min + (self.Max - self.Min) * RelativeX
            self:Set(Value)
        end
        
        Library:Connect(UserInputService.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and self.Window.IsOpen then
                local MousePos = UserInputService:GetMouseLocation()
                local TrackPos = Track.RealPosition
                local TrackSize = Track.RealSize
                
                if MousePos.X >= TrackPos.X - 5 and MousePos.X <= TrackPos.X + TrackSize.X + 5 and
                   MousePos.Y >= TrackPos.Y - 5 and MousePos.Y <= TrackPos.Y + TrackSize.Y + 5 then
                    self.Sliding = true
                    UpdateSlider(Input)
                end
            end
        end)
        
        Library:Connect(UserInputService.InputChanged, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement and self.Sliding then
                UpdateSlider(Input)
            end
        end)
        
        Library:Connect(UserInputService.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                self.Sliding = false
            end
        end)
        
        Slider:Set(Slider.Default)
        self.CurrentY = self.CurrentY + 35
        self.Height = self.Height + 35
        
        Library.SetFlags[Slider.Flag] = function(Value)
            Slider:Set(Value)
        end
        
        return Slider
    end

