    -- Utility functions
    function Library:Unload()
        for _, Connection in ipairs(self.Connections) do
            if Connection.Connection then
                Connection.Connection:Disconnect()
            end
        end
        
        for _, Thread in ipairs(self.Threads) do
            coroutine.close(Thread)
        end
        
        if self.Cursor then
            self.Cursor:Destroy()
        end
        
        UserInputService.MouseIconEnabled = true
        Library = nil
        getgenv().Library = nil
    end

    function Library:Connect(Event, Callback, Name)
        Name = Name or StringFormat("Connection%s", self.UnnamedConnections + 1)
        
        local Connection = Event:Connect(Callback)
        
        TableInsert(self.Connections, {
            Name = Name,
            Connection = Connection
        })
        
        return Connection
    end

    function Library:Thread(Function)
        local NewThread = coroutine.create(Function)
        coroutine.wrap(function()
            coroutine.resume(NewThread)
        end)()
        TableInsert(self.Threads, NewThread)
        return NewThread
    end

    function Library:SafeCall(Function, ...)
        local Success, Result = pcall(Function, ...)
        if not Success then
            warn("Library Error:", Result)
            return false
        end
        return Success, Result
    end

    function Library:NextFlag()
        self.UnnamedFlags = self.UnnamedFlags + 1
        return StringFormat("flag_%d", self.UnnamedFlags)
    end

    function Library:Round(Number, Float)
        local Multiplier = 1 / (Float or 1)
        return MathFloor(Number * Multiplier) / Multiplier
    end

    -- Config system
    function Library:GetConfig()
        local Config = {}
        for Index, Value in pairs(self.Flags) do
            Config[Index] = Value
        end
        return HttpService:JSONEncode(Config)
    end

    function Library:LoadConfig(ConfigString)
        local Success, Decoded = pcall(HttpService.JSONDecode, HttpService, ConfigString)
        if Success and Decoded then
            for Index, Value in pairs(Decoded) do
                local SetFunction = self.SetFlags[Index]
                if SetFunction then
                    SetFunction(Value)
                end
            end
        end
    end

    function Library:SaveConfig(Name)
        local Path = self.Folders.Configs .. "/" .. Name .. ".json"
        writefile(Path, self:GetConfig())
    end

    function Library:DeleteConfig(Name)
        local Path = self.Folders.Configs .. "/" .. Name .. ".json"
        if isfile(Path) then
            delfile(Path)
        end
    end

    function Library:ListConfigs()
        local Configs = {}
        for _, File in ipairs(listfiles(self.Folders.Configs)) do
            local Name = File:match("([^/\\]+)%.json$")
            if Name then
                TableInsert(Configs, Name)
            end
        end
        return Configs
    end
end

getgenv().Library = Library
return Library
