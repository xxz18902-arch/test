        -- Column layout
        Page.ColumnsData = {}
        local ColumnWidth = (1 - 20 / self.ContentArea.RealSize.X) / Page.Columns
        
        for i = 1, Page.Columns do
            local Column = DrawingProxy.new("Image", {
                Parent = PageContent,
                Position = UDim2New(0, (i - 1) * (self.ContentArea.RealSize.X - 20) / Page.Columns + (i - 1) * 10, 0, 0),
                Size = UDim2New(0, (self.ContentArea.RealSize.X - 20) / Page.Columns - 10, 1, 0),
