            Data = PixelData,
            ZIndex = 99
        })
        
        function Dropdown:AddOption(OptionName)
            local OptionY = (#self.Options * 20)
            
            local OptionBtn = DrawingProxy.new("Image", {
                Parent = OptionsContainer,
                Position = UDim2New(0, 5, 0, 5 + OptionY),
                Size = UDim2New(1, -10, 0, 18),
                Color = Colors.Element,
                Rounding = 4,
                Transparency = 1,
                Data = PixelData,
                ZIndex = 101
            })
            
            local OptionText = DrawingProxy.new("Text", {
                Parent = OptionBtn,
                Position = UDim2New(0, 8, 0, 2),
                Size = 12,
                Color = Colors.TextActive,
                Text = OptionName,
                Font = 1,
                Transparency = 1,
                ZIndex = 102
            })
            
            local OptionData = {
                Name = OptionName,
                Button = OptionBtn,
                Text = OptionText,
                Selected = false
            }
            
            function OptionData:Select()
                if Dropdown.Multi then
                    self.Selected = not self.Selected
                    
                    if self.Selected then
                        TweenObject(self.Button.Object, {Color = Colors.Accent}, 0.15, "Circular")
                        TweenObject(self.Text.Object, {Color = Colors.Black}, 0.15, "Circular")
                        TableInsert(Dropdown.Value, self.Name)
                    else
                        TweenObject(self.Button.Object, {Color = Colors.Element}, 0.15, "Circular")
                        TweenObject(self.Text.Object, {Color = Colors.TextActive}, 0.15, "Circular")
                        
                        local Index = TableFind(Dropdown.Value, self.Name)
                        if Index then
                            TableRemove(Dropdown.Value, Index)
                        end
                    end
                    
                    DropdownText.Text = #Dropdown.Value == 0 and "--" or TableConcat(Dropdown.Value, ", ")
                else
                    -- Deselect all others
                    for _, Opt in pairs(Dropdown.Options) do
                        Opt.Selected = false
                        TweenObject(Opt.Button.Object, {Color = Colors.Element}, 0.15, "Circular")
                        TweenObject(Opt.Text.Object, {Color = Colors.TextActive}, 0.15, "Circular")
                    end
                    
                    self.Selected = true
                    TweenObject(self.Button.Object, {Color = Colors.Accent}, 0.15, "Circular")
                    TweenObject(self.Text.Object, {Color = Colors.Black}, 0.15, "Circular")
                    
                    Dropdown.Value = self.Name
                    DropdownText.Text = self.Name
                    
                    -- Close dropdown
                    Dropdown:SetOpen(false)
                end
                
                Library.Flags[Dropdown.Flag] = Dropdown.Value
                if Dropdown.Callback then
                    Library:SafeCall(Dropdown.Callback, Dropdown.Value)
                end
            end
            
            -- Click handling
            Library:Connect(UserInputService.InputBegan, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 and Dropdown.IsOpen then
                    local MousePos = UserInputService:GetMouseLocation()
                    local BtnPos = OptionBtn.RealPosition
                    local BtnSize = OptionBtn.RealSize
                    
                    if MousePos.X >= BtnPos.X and MousePos.X <= BtnPos.X + BtnSize.X and
                       MousePos.Y >= BtnPos.Y and MousePos.Y <= BtnPos.Y + BtnSize.Y then
                        OptionData:Select()
                    end
                end
            end)
            
            TableInsert(self.Options, OptionData)
            
            -- Update container size
            OptionsContainer.Size = UDim2New(0, 200, 0, 10 + (#self.Options * 20))
        end
        
        function Dropdown:SetOpen(Bool)
            self.IsOpen = Bool
            
            if Bool then
                -- Position container below dropdown
                local BtnPos = DropdownBtn.RealPosition
                OptionsContainer.Position = UDim2New(0, BtnPos.X, 0, BtnPos.Y + 25)
                OptionsContainer.Visible = true
                
                TweenObject(OptionsContainer.Object, {Transparency = 1}, 0.15, "Circular")
                TweenObject(OptionsBorder.Object, {Transparency = 1}, 0.15, "Circular")
                TweenObject(Arrow.Object, {Rotation = 90}, 0.15, "Circular")
            else
                TweenObject(OptionsContainer.Object, {Transparency = 0}, 0.15, "Circular")
                TweenObject(OptionsBorder.Object, {Transparency = 0}, 0.15, "Circular")
                TweenObject(Arrow.Object, {Rotation = 0}, 0.15, "Circular")
                
                task.delay(0.15, function()
                    OptionsContainer.Visible = false
                end)
            end
        end
        
        -- Click handling for main button
        Library:Connect(UserInputService.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and self.Window.IsOpen then
                local MousePos = UserInputService:GetMouseLocation()
                local BtnPos = DropdownBtn.RealPosition
                local BtnSize = DropdownBtn.RealSize
                
                if MousePos.X >= BtnPos.X and MousePos.X <= BtnPos.X + BtnSize.X and
                   MousePos.Y >= BtnPos.Y and MousePos.Y <= BtnPos.Y + BtnSize.Y then
                    Dropdown:SetOpen(not Dropdown.IsOpen)
                elseif Dropdown.IsOpen then
                    -- Close if clicking outside
                    local ContPos = OptionsContainer.RealPosition
                    local ContSize = OptionsContainer.RealSize
                    
                    if not (MousePos.X >= ContPos.X and MousePos.X <= ContPos.X + ContSize.X and
                            MousePos.Y >= ContPos.Y and MousePos.Y <= ContPos.Y + ContSize.Y) then
                        Dropdown:SetOpen(false)
                    end
                end
            end
        end)
        
        -- Add initial options
        for _, Item in ipairs(Dropdown.Items) do
            Dropdown:AddOption(Item)
        end
        
        if Dropdown.Default then
            if Dropdown.Multi then
                for _, Val in ipairs(Dropdown.Default) do
                    for _, Opt in ipairs(Dropdown.Options) do
                        if Opt.Name == Val then
                            Opt:Select()
                        end
                    end
                end
            else
                for _, Opt in ipairs(Dropdown.Options) do
                    if Opt.Name == Dropdown.Default then
                        Opt:Select()
                    end
                end
            end
        end
        
        self.CurrentY = self.CurrentY + 45
        self.Height = self.Height + 45
        
        Library.SetFlags[Dropdown.Flag] = function(Value)
            Dropdown:Set(Value)
        end
        
        return Dropdown
    end

