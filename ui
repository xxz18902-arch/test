                Rounding = 0,
                Transparency = 0,
                Data = PixelData,
                ZIndex = 54
            })
            TableInsert(Page.ColumnsData, Column)
        end
        
        function Page:Turn(Bool)
            self.Active = Bool
            
            if Bool then
                -- Highlight tab
                TweenObject(self.TabButton.Object, {Color = Colors.TextActive}, 0.2, "Exponential")
                
                -- Move tab line
                TweenObject(self.Window.TabLine.Object, {
                    Position = UDim2New(0, 0, 0, 50 + (self.TabIndex - 1) * 25 + 1)
                }, 0.2, "Circular")
                
                -- Show content
                self.Content.Visible = true
                TweenObject(self.Content.Object, {Transparency = 1}, self.Window.FadeSpeed, "Exponential")
                
                -- Update current tab
                self.Window.CurrentTab = self
            else
                TweenObject(self.TabButton.Object, {Color = Colors.TextInactive}, 0.2, "Exponential")
                TweenObject(self.Content.Object, {Transparency = 0}, self.Window.FadeSpeed, "Exponential")
                
                task.delay(self.Window.FadeSpeed, function()
                    self.Content.Visible = false
                end)
            end
        end
        
        -- Click handling
        Library:Connect(UserInputService.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and self.Window.IsOpen then
                local MousePos = UserInputService:GetMouseLocation()
                local AreaPos = TabArea.RealPosition
                local AreaSize = TabArea.RealSize
                
                if MousePos.X >= AreaPos.X and MousePos.X <= AreaPos.X + AreaSize.X and
                   MousePos.Y >= AreaPos.Y and MousePos.Y <= AreaPos.Y + AreaSize.Y then
                    -- Deactivate other tabs
                    for _, OtherPage in ipairs(self.Window.Tabs) do
                        if OtherPage ~= self and OtherPage.Active then
                            OtherPage:Turn(false)
                        end
                    end
                    self:Turn(true)
                end
            end
        end)
        
        -- Hover effect
        Library:Connect(UserInputService.InputChanged, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement and self.Window.IsOpen and not self.Active then
                local MousePos = UserInputService:GetMouseLocation()
                local AreaPos = TabArea.RealPosition
                local AreaSize = TabArea.RealSize
                
                if MousePos.X >= AreaPos.X and MousePos.X <= AreaPos.X + AreaSize.X and
                   MousePos.Y >= AreaPos.Y and MousePos.Y <= AreaPos.Y + AreaSize.Y then
                    TweenObject(self.TabButton.Object, {Color = Colors.BorderHighlight}, 0.17, "Circular")
                else
                    TweenObject(self.TabButton.Object, {Color = Colors.TextInactive}, 0.17, "Circular")
                end
            end
        end)
        
        TableInsert(self.Tabs, Page)
        
        -- First page active by default
        if #self.Tabs == 1 then
            Page:Turn(true)
        end
        
        return setmetatable(Page, Library.Pages)
    end

    -- Enhanced Section
    function Library.Pages:Section(Data)
