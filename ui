    -- Custom Drawing Proxy (Juju pattern)
    local DrawingProxy = {}
    DrawingProxy.__index = DrawingProxy
    
    function DrawingProxy.new(Class, Properties)
        local Object = DrawingNew(Class)
        
        local Proxy = setmetatable({
            Object = Object,
            Position = UDim2New(0, 0, 0, 0),
            Size = Class == "Text" and 12 or UDim2New(0, 0, 0, 0),
            RealPosition = Vector2New(0, 0),
            RealSize = Vector2New(0, 0),
            Parent = nil,
            Children = {},
            Visible = false,
            IsRendering = false
        }, DrawingProxy)
        
        for Property, Value in pairs(Properties or {}) do
            Proxy[Property] = Value
        end
        
        return Proxy
    end
    
    function DrawingProxy:__newindex(Property, Value)
        if Property == "Position" then
            self.Position = Value
            self:UpdatePosition()
        elseif Property == "Size" and type(Value) ~= "number" then
            self.Size = Value
            self:UpdateSize()
        elseif Property == "Parent" then
            if Value then
                TableInsert(Value.Children, self)
            end
            self.Parent = Value
            self:UpdatePosition()
            self:UpdateVisibility()
        elseif Property == "Visible" then
            self.Visible = Value
            self:UpdateVisibility()
        else
            self.Object[Property] = Value
        end
    end
    
    function DrawingProxy:__index(Property)
        if Property == "Object" then return rawget(self, "Object") end
        return self.Object[Property] or rawget(self, Property)
    end
    
    function DrawingProxy:UpdatePosition()
        local Parent = self.Parent
        local RealPos = Parent and Parent.RealPosition or Vector2New(self.Position.X.Offset, self.Position.Y.Offset)
        
        if Parent then
            RealPos = Vector2New(
                Parent.RealPosition.X + Parent.RealSize.X * self.Position.X.Scale + self.Position.X.Offset,
                Parent.RealPosition.Y + Parent.RealSize.Y * self.Position.Y.Scale + self.Position.Y.Offset
            )
        end
        
        self.RealPosition = RealPos
        self.Object.Position = RealPos
        
        for _, Child in ipairs(self.Children) do
            Child:UpdatePosition()
        end
    end
    
    function DrawingProxy:UpdateSize()
        if type(self.Size) == "number" then return end
        
        local Parent = self.Parent
        local RealSize = Parent and Parent.RealSize or Vector2New(self.Size.X.Offset, self.Size.Y.Offset)
        
        if Parent then
            RealSize = Vector2New(
                Parent.RealSize.X * self.Size.X.Scale + self.Size.X.Offset,
                Parent.RealSize.Y * self.Size.Y.Scale + self.Size.Y.Offset
            )
        end
        
        self.RealSize = RealSize
        self.Object.Size = RealSize
        
        for _, Child in ipairs(self.Children) do
            Child:UpdatePosition()
        end
    end
    
    function DrawingProxy:UpdateVisibility()
        local Parent = self.Parent
        local ShouldRender = self.Visible and (not Parent or Parent.IsRendering)
        
        self.IsRendering = ShouldRender
        self.Object.Visible = ShouldRender
        
        for _, Child in ipairs(self.Children) do
            Child:UpdateVisibility()
        end
    end
    
    function DrawingProxy:Destroy()
        for _, Child in ipairs(self.Children) do
            Child:Destroy()
        end
        self.Object:Remove()
    end

    -- Juju-style Tween System
    local ActiveTweens = {}
    
    local function Lerp(A, B, T)
        return A + (B - A) * T
    end
    
    local function EaseExponential(T)
        return T == 1 and 1 or 1 - 2 ^ (-10 * T)
    end
    
    local function EaseCircular(T)
        return MathSqrt(1 - (T - 1) ^ 2)
    end
    
    local function EaseQuad(T)
        return T ^ 2
    end
    
    local function TweenObject(Object, Properties, Duration, EasingStyle)
        local StartTime = tick()
        local StartValues = {}
        
        for Property, _ in pairs(Properties) do
            StartValues[Property] = Object[Property]
        end
        
        local Connection
        Connection = RunService.RenderStepped:Connect(function()
            local Elapsed = tick() - StartTime
            local T = MathClamp(Elapsed / Duration, 0, 1)
            
            local EasedT = EasingStyle == "Exponential" and EaseExponential(T)
                or EasingStyle == "Circular" and EaseCircular(T)
                or EasingStyle == "Quad" and EaseQuad(T)
                or T
            
            for Property, TargetValue in pairs(Properties) do
                if typeof(TargetValue) == "Color3" then
                    Object[Property] = StartValues[Property]:Lerp(TargetValue, EasedT)
                elseif typeof(TargetValue) == "UDim2" then
                    local Start = StartValues[Property]
                    Object[Property] = UDim2New(
                        Lerp(Start.X.Scale, TargetValue.X.Scale, EasedT),
                        Lerp(Start.X.Offset, TargetValue.X.Offset, EasedT),
                        Lerp(Start.Y.Scale, TargetValue.Y.Scale, EasedT),
                        Lerp(Start.Y.Offset, TargetValue.Y.Offset, EasedT)
                    )
                elseif typeof(TargetValue) == "Vector2" then
                    Object[Property] = StartValues[Property]:Lerp(TargetValue, EasedT)
                else
                    Object[Property] = Lerp(StartValues[Property], TargetValue, EasedT)
                end
            end
            
            if T >= 1 then
                Connection:Disconnect()
            end
        end)
        
        TableInsert(ActiveTweens, Connection)
        return Connection
    end

