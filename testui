    local function RecalculateList()
        ListOuter.Position = UDim2.fromOffset(Outer.AbsolutePosition.X, Outer.AbsolutePosition.Y + Outer.AbsoluteSize.Y + 1)
        ListOuter.Size = UDim2.fromOffset(Outer.AbsoluteSize.X, math.min(#Dropdown.Values * 22 + 2, 180))
    end
    function Dropdown:Display()
        local Str = ""
        if Info.Multi then
            for _, Value in ipairs(Dropdown.Values) do
                if Dropdown.Value[Value] then
                    Str = Str .. Value .. ", "
                end
            end
            Str = Str:sub(1, -3)
        else
            Str = Dropdown.Value or ""
        end
        ItemList.Text = Str == "" and "--" or Str
    end
    function Dropdown:BuildList()
        for _, Child in ipairs(Scrolling:GetChildren()) do
            if not Child:IsA("UIListLayout") then
                Child:Destroy()
            end
        end
        for _, Value in ipairs(Dropdown.Values) do
            local Button = Library:Create("Frame", {
                BackgroundColor3 = Library.MainColor,
                BorderColor3 = Library.OutlineColor,
                BorderMode = Enum.BorderMode.Middle,
                Size = UDim2.new(1, -1, 0, 22),
                ZIndex = 23,
                Active = true,
                Parent = Scrolling
            })
            local ButtonLabel = Library:CreateLabel({
                Size = UDim2.new(1, -12, 1, 0),
                Position = UDim2.fromOffset(6, 0),
                Text = Value,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 25,
                Parent = Button
            })
            Library:AddToRegistry(Button, {
                BackgroundColor3 = "MainColor",
                BorderColor3 = "OutlineColor"
            })
            Library:OnHighlight(Button, Button,
                { BorderColor3 = "AccentColor", ZIndex = 24 },
                { BorderColor3 = "OutlineColor", ZIndex = 23 }
            )
            local Selected = Info.Multi and Dropdown.Value[Value] or Dropdown.Value == Value
            local function Update()
                Selected = Info.Multi and Dropdown.Value[Value] or Dropdown.Value == Value
                ButtonLabel.TextColor3 = Selected and Library.AccentColor or Library.FontColor
                local Reg = Library.RegistryMap[ButtonLabel]
                if Reg then
                    Reg.Properties.TextColor3 = Selected and "AccentColor" or "FontColor"
                end
            end
            ButtonLabel.InputBegan:Connect(function(Input)
                if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                if Info.Multi then
                    Dropdown.Value[Value] = not Selected and true or nil
                else
                    Dropdown.Value = not Selected and Value or nil
                    Dropdown:Close()
                end
                Update()
                Dropdown:Display()
                Library:SafeCallback(Dropdown.Callback, Dropdown.Value)
                if Dropdown.Changed then
                    Library:SafeCallback(Dropdown.Changed, Dropdown.Value)
                end
            end)
            Update()
        end
        Scrolling.CanvasSize = UDim2.fromOffset(0, #Dropdown.Values * 22 + 1)
    end
    function Dropdown:Open()
        RecalculateList()
        ListOuter.Visible = true
        Library.OpenedFrames[ListOuter] = true
        Arrow.Rotation = 180
        Dropdown:BuildList()
    end
    function Dropdown:Close()
        ListOuter.Visible = false
        Library.OpenedFrames[ListOuter] = nil
        Arrow.Rotation = 0
    end
    function Dropdown:SetValue(Val)
        if Info.Multi then
            Dropdown.Value = {}
            for Value, Bool in pairs(Val) do
                if table.find(Dropdown.Values, Value) then
                    Dropdown.Value[Value] = Bool
                end
            end
        else
            Dropdown.Value = table.find(Dropdown.Values, Val) and Val or nil
        end
        Dropdown:Display()
        Dropdown:BuildList()
    end
    function Dropdown:OnChanged(Func)
        Dropdown.Changed = Func
        Func(Dropdown.Value)
    end
    Outer.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 and not Library:MouseIsOverOpenedFrame() then
            if ListOuter.Visible then
                Dropdown:Close()
            else
                Dropdown:Open()
            end
        end
    end)
    UserInputService.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 and ListOuter.Visible then
            if not Library:IsMouseOverFrame(ListOuter) and not Library:IsMouseOverFrame(Outer) then
                Dropdown:Close()
            end
        end
    end)
    Dropdown:Display()
    Dropdown:BuildList()
    self:AddBlank(7)
    self:Resize()
    Options[Idx] = Dropdown
    return Dropdown
end

