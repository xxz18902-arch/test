        TextColor3 = Library.FontColor,
        TextSize = 14,
        TextStrokeTransparency = 0,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 7,
        Parent = Container
    })
    Library:ApplyTextStroke(Box)
    Library:AddToRegistry(Outer, { BorderColor3 = "Black" })
    Library:AddToRegistry(Inner, {
        BackgroundColor3 = "MainColor",
        BorderColor3 = "OutlineColor"
    })
    Library:AddToRegistry(Box, { TextColor3 = "FontColor" })
    Library:OnHighlight(Outer, Outer,
        { BorderColor3 = "AccentColor" },
        { BorderColor3 = "Black" }
    )
    if Info.Tooltip then
        Library:AddTooltip(Info.Tooltip, Outer)
    end
    function Input:SetValue(Text)
        if Info.MaxLength and #Text > Info.MaxLength then
            Text = Text:sub(1, Info.MaxLength)
        end
        if Input.Numeric and Text ~= "" and not tonumber(Text) then
            Text = Input.Value
        end
        Input.Value = Text
        Box.Text = Text
        Library:SafeCallback(Input.Callback, Input.Value)
        if Input.Changed then
            Library:SafeCallback(Input.Changed, Input.Value)
        end
    end
    function Input:OnChanged(Func)
        Input.Changed = Func
        Func(Input.Value)
    end
    if Input.Finished then
        Box.FocusLost:Connect(function(Enter)
            if Enter then
                Input:SetValue(Box.Text)
            end
        end)
    else
        Box:GetPropertyChangedSignal("Text"):Connect(function()
            Input:SetValue(Box.Text)
        end)
    end
    local function UpdateCursor()
        if not Box:IsFocused() then
            Box.Position = UDim2.fromOffset(2, 0)
            return
        end
        local Cursor = Box.CursorPosition
        if Cursor == -1 then return end
        local SubText = Box.Text:sub(1, Cursor - 1)
        local Width = TextService:GetTextSize(SubText, 14, Library.Font, Vector2.new(math.huge, math.huge)).X
        local CurrentPos = Box.Position.X.Offset + Width
        if CurrentPos < 2 then
            Box.Position = UDim2.fromOffset(2 - Width, 0)
        elseif CurrentPos > Container.AbsoluteSize.X - 4 then
            Box.Position = UDim2.fromOffset(Container.AbsoluteSize.X - Width - 4, 0)
        end
    end
    Box:GetPropertyChangedSignal("Text"):Connect(UpdateCursor)
    Box:GetPropertyChangedSignal("CursorPosition"):Connect(UpdateCursor)
    Box.Focused:Connect(UpdateCursor)
    Box.FocusLost:Connect(function() Box.Position = UDim2.fromOffset(2, 0) end)
    self:AddBlank(7)
    self:Resize()
    Options[Idx] = Input
    return Input
end

function BaseGroupbox:AddDependencyBox()
    local Depbox = {
        Dependencies = {}
    }
