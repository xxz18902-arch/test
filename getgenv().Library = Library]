            Parent = SliderOuter;
            Visible = false; -- يظهر عند الهوفر
        });
        
        Library:Create('UICorner', {CornerRadius = UDim.new(1, 0), Parent = Handle});
        Library:Create('UIStroke', {Color = Library.AccentColor, Thickness=2, Parent=Handle});

        -- Value Label (فوق الماوس)
        local ValueLabel = Library:CreateLabel({
            Size = UDim2.new(0, 40, 0, 20);
            Position = UDim2.new(0, 0, 0, -25);
            TextSize = 12;
            Text = tostring(Slider.Value);
            TextXAlignment = Enum.TextXAlignment.Center;
            ZIndex = 10;
            Parent = Handle;
            Visible = false;
        });
        
        -- خلفية للقيمة
        local ValueBg = Library:Create('Frame', {
            BackgroundColor3 = Library.MainColor;
            BorderSizePixel = 0;
            Size = UDim2.new(1, 4, 1, 4);
            Position = UDim2.new(0, -2, 0, -2);
            ZIndex = 9;
            Parent = ValueLabel;
        });
        Library:Create('UICorner', {CornerRadius = UDim.new(0, 4), Parent = ValueBg});

        Library:AddToRegistry(SliderOuter, {BackgroundColor3 = 'OutlineColor'});
        Library:AddToRegistry(Fill, {BackgroundColor3 = 'AccentColor'});
        Library:AddToRegistry(FillGlow, {BackgroundColor3 = 'AccentColor'});

        SliderInner = SliderOuter; -- للتوافق مع الكود القديم

        function Slider:Display()
            local Suffix = Info.Suffix or '';
            local X = math.ceil(Library:MapValue(Slider.Value, Slider.Min, Slider.Max, 0, SliderOuter.AbsoluteSize.X));
            
            -- Tween سلس للـ Fill
            Library:SmoothTween(Fill, {Size = UDim2.new(0, X, 1, 0)}, 0.1):Play();
            Library:SmoothTween(Handle, {Position = UDim2.new(0, X, 0.5, 0)}, 0.1):Play();
            
            ValueLabel.Text = tostring(Slider.Value) .. Suffix;
        end;

        local function Round(Value)
            if Slider.Rounding == 0 then return math.floor(Value); end;
            return tonumber(string.format('%.' .. Slider.Rounding .. 'f', Value))
        end;

        function Slider:GetValueFromXOffset(X)
            return Round(Library:MapValue(X, 0, SliderOuter.AbsoluteSize.X, Slider.Min, Slider.Max));
        end;

        function Slider:SetValue(Str)
            local Num = tonumber(Str);
            if (not Num) then return; end;
            Num = math.clamp(Num, Slider.Min, Slider.Max);
            Slider.Value = Num;
            Slider:Display();
            Library:SafeCallback(Slider.Callback, Slider.Value);
            Library:SafeCallback(Slider.Changed, Slider.Value);
        end;

        -- Interactions
        SliderOuter.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and not Library:MouseIsOverOpenedFrame() then
                Handle.Visible = true;
                ValueLabel.Visible = true;
                
                while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                    local MouseX = math.clamp(Mouse.X - SliderOuter.AbsolutePosition.X, 0, SliderOuter.AbsoluteSize.X);
                    local NewValue = Slider:GetValueFromXOffset(MouseX);
                    
                    if NewValue ~= Slider.Value then
                        Slider.Value = NewValue;
                        Slider:Display();
                        Library:SafeCallback(Slider.Callback, Slider.Value);
                        Library:SafeCallback(Slider.Changed, Slider.Value);
                    end;
                    RenderStepped:Wait();
                end;
                
                task.wait(0.5);
                Handle.Visible = false;
                ValueLabel.Visible = false;
            end;
        end);
        
        SliderOuter.MouseEnter:Connect(function()
            if not InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                Handle.Visible = true;
            end
        end)
        
        SliderOuter.MouseLeave:Connect(function()
            if not InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                Handle.Visible = false;
                ValueLabel.Visible = false;
            end
        end)

        Slider:Display();
        Groupbox:AddBlank(Info.BlankSize or 10);
        Groupbox:Resize();
        Options[Idx] = Slider;
        return Slider;
    end;

