            ZIndex = 5;
            Parent = Fill;
        });
        Library:Create('UICorner', {CornerRadius = UDim.new(1, 0), Parent = FillGlow});

        -- Handle (الدائرة المتحركة)
        local Handle = Library:Create('Frame', {
            AnchorPoint = Vector2.new(0.5, 0.5);
            BackgroundColor3 = Color3.new(1, 1, 1);
            BorderSizePixel = 0;
            Size = UDim2.new(0, 16, 0, 16);
