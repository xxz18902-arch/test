    -- MODERN BUTTON
    function Funcs:AddButton(...)
        local Button = {};
        local function ProcessButtonParams(Class, Obj, ...)
            local Props = select(1, ...)
            if type(Props) == 'table' then
                Obj.Text = Props.Text
                Obj.Func = Props.Func
                Obj.DoubleClick = Props.DoubleClick
                Obj.Tooltip = Props.Tooltip
            else
                Obj.Text = select(1, ...)
                Obj.Func = select(2, ...)
            end
            assert(type(Obj.Func) == 'function', 'AddButton: `Func` callback is missing.');
        end

        ProcessButtonParams('Button', Button, ...)
        local Groupbox = self;
        local Container = Groupbox.Container;

        local function CreateBaseButton(Button)
            local Outer = Library:Create('Frame', {
                BackgroundColor3 = Library.OutlineColor; -- Stroke effect
                BorderSizePixel = 0;
                Size = UDim2.new(1, -8, 0, 26); -- أطول قليلاً
                ZIndex = 5;
            });
            
            Library:Create('UICorner', {CornerRadius = UDim.new(0, 6), Parent = Outer});

            local Inner = Library:Create('Frame', {
                BackgroundColor3 = Library.MainColor;
                BorderSizePixel = 0;
                Size = UDim2.new(1, -2, 1, -2);
                Position = UDim2.fromOffset(1, 1);
                ZIndex = 6;
                Parent = Outer;
            });
            
            Library:Create('UICorner', {CornerRadius = UDim.new(0, 5), Parent = Inner});

            -- Gradient
            local Gradient = Library:Create('UIGradient', {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(240, 240, 240))
                });
                Rotation = -90;
                Transparency = NumberSequence.new(0.95, 0.98);
                Parent = Inner;
            });

            local Label = Library:CreateLabel({
                Size = UDim2.new(1, 0, 1, 0);
                TextSize = 14;
                Text = Button.Text;
                ZIndex = 7;
                Parent = Inner;
            });

            Library:AddToRegistry(Outer, {BackgroundColor3 = 'OutlineColor'});
            Library:AddToRegistry(Inner, {BackgroundColor3 = 'MainColor'});

            -- Smooth Highlight
            Library:OnHighlight(Outer, Outer,
                { BackgroundColor3 = Library.AccentColor },
                { BackgroundColor3 = Library.OutlineColor }
            );

            return Outer, Inner, Label
        end

        local function InitEvents(Button)
            Button.Outer.InputBegan:Connect(function(Input)
                if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                if Library:MouseIsOverOpenedFrame() then return end
                if Button.Locked then return end

                if Button.DoubleClick then
                    Button.Label.Text = 'Confirm?'
                    Library:SmoothTween(Button.Inner, {BackgroundColor3 = Library.AccentColor}, 0.2):Play()
                    task.wait(0.3)
                    Button.Label.Text = Button.Text
                    Library:SmoothTween(Button.Inner, {BackgroundColor3 = Library.MainColor}, 0.2):Play()
                    return
                end
                
                -- Click Effect (Scale down slightly)
                Library:SmoothTween(Button.Inner, {Size = UDim2.new(1, -4, 1, -4), Position = UDim2.fromOffset(2, 2)}, 0.1):Play()
                task.wait(0.1)
                Library:SmoothTween(Button.Inner, {Size = UDim2.new(1, -2, 1, -2), Position = UDim2.fromOffset(1, 1)}, 0.1):Play()
                
                Library:SafeCallback(Button.Func);
            end)
        end

        Button.Outer, Button.Inner, Button.Label = CreateBaseButton(Button)
        Button.Outer.Parent = Container
        InitEvents(Button)

        function Button:AddTooltip(tooltip)
            if type(tooltip) == 'string' then Library:AddToolTip(tooltip, self.Outer) end
            return self
        end

        function Button:AddButton(...)
            local SubButton = {}
            ProcessButtonParams('SubButton', SubButton, ...)
            self.Outer.Size = UDim2.new(0.5, -6, 0, 26)
            SubButton.Outer, SubButton.Inner, SubButton.Label = CreateBaseButton(SubButton)
            SubButton.Outer.Position = UDim2.new(1, 4, 0, 0)
            SubButton.Outer.Size = UDim2.new(1, -4, 1, 0)
            SubButton.Outer.Parent = self.Outer
            
            self.Outer:GetPropertyChangedSignal('AbsoluteSize'):Connect(function()
                SubButton.Outer.Size = UDim2.new(1, -4, 1, 0)
            end)
            
            function SubButton:AddTooltip(tooltip)
                if type(tooltip) == 'string' then Library:AddToolTip(tooltip, self.Outer) end
                return SubButton
            end
            if type(SubButton.Tooltip) == 'string' then SubButton:AddTooltip(SubButton.Tooltip) end
            InitEvents(SubButton)
            return SubButton
        end

        if type(Button.Tooltip) == 'string' then Button:AddTooltip(Button.Tooltip) end
        Groupbox:AddBlank(8);
        Groupbox:Resize();
        return Button;
    end;

