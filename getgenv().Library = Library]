            Position = UDim2.fromOffset(1, 1);
            ZIndex = 6;
            Parent = DropdownOuter;
        });
        
        Library:Create('UICorner', {CornerRadius = UDim.new(0, 5), Parent = DropdownInner});

        -- Arrow Icon (مثلث أنيق)
        local DropdownArrow = Library:Create('ImageLabel', {
            AnchorPoint = Vector2.new(0.5, 0.5);
            BackgroundTransparency = 1;
            Position = UDim2.new(1, -16, 0.5, 0);
            Size = UDim2.new(0, 12, 0, 12);
            Image = 'rbxassetid://7072706748'; -- سهم أنيق
            ImageColor3 = Library.FontColor;
            ZIndex = 8;
            Parent = DropdownInner;
        });

        local ItemList = Library:CreateLabel({
            Position = UDim2.new(0, 10, 0, 0);
            Size = UDim2.new(1, -35, 1, 0);
            TextSize = 14;
            Text = (Info.Multi and '--' or (Info.Default or '--'));
            TextXAlignment = Enum.TextXAlignment.Left;
            TextWrapped = true;
            ZIndex = 7;
            Parent = DropdownInner;
        });

        Library:OnHighlight(DropdownOuter, DropdownOuter,
            { BackgroundColor3 = Library.AccentColor },
            { BackgroundColor3 = Library.OutlineColor }
        );

        -- List Frame (ناعم)
        local MAX_DROPDOWN_ITEMS = 8;
        local ListOuter = Library:Create('Frame', {
            BackgroundColor3 = Library.BackgroundColor;
            BorderSizePixel = 0;
            ZIndex = 20;
            Visible = false;
            Parent = ScreenGui;
            ClipsDescendants = true;
        });
        
        Library:Create('UICorner', {CornerRadius = UDim.new(0, 8), Parent = ListOuter});
        
        -- Shadow
        local ListShadow = Library:Create('ImageLabel', {
            AnchorPoint = Vector2.new(0.5, 0.5);
            BackgroundTransparency = 1;
            Position = UDim2.new(0.5, 0, 0.5, 4);
            Size = UDim2.new(1, 20, 1, 20);
            Image = 'rbxassetid://6014261993';
            ImageTransparency = 0.7;
            ZIndex = 19;
            Parent = ListOuter;
        });

        local ListInner = Library:Create('ScrollingFrame', {
            BackgroundTransparency = 1;
            BorderSizePixel = 0;
            CanvasSize = UDim2.new(0, 0, 0, 0);
            Size = UDim2.new(1, -16, 1, -16);
            Position = UDim2.fromOffset(8, 8);
            ZIndex = 21;
            Parent = ListOuter;
            ScrollBarThickness = 4;
            ScrollBarImageColor3 = Library.AccentColor;
        });

        Library:Create('UIListLayout', {
            Padding = UDim.new(0, 4);
            FillDirection = Enum.FillDirection.Vertical;
            Parent = ListInner;
        });

        -- Recalculate Functions
        local function RecalculateListPosition()
            ListOuter.Position = UDim2.fromOffset(DropdownOuter.AbsolutePosition.X, DropdownOuter.AbsolutePosition.Y + DropdownOuter.AbsoluteSize.Y + 4);
        end;
        local function RecalculateListSize()
            ListOuter.Size = UDim2.fromOffset(DropdownOuter.AbsoluteSize.X, 0); -- يبدأ بارتفاع 0 للـ animation
        end;

        DropdownOuter:GetPropertyChangedSignal('AbsolutePosition'):Connect(RecalculateListPosition);
        DropdownOuter:GetPropertyChangedSignal('AbsoluteSize'):Connect(function()
            RecalculateListPosition();
            ListOuter.Size = UDim2.fromOffset(DropdownOuter.AbsoluteSize.X, ListOuter.Size.Y.Offset);
        end);

        function Dropdown:Display()
            local Values = Dropdown.Values;
            local Str = '';
            if Info.Multi then
                for Idx, Value in next, Values do
                    if Dropdown.Value[Value] then Str = Str .. Value .. ', '; end;
                end;
                Str = Str:sub(1, #Str - 2);
            else
                Str = Dropdown.Value or '--';
            end;
            ItemList.Text = Str;
        end;

        function Dropdown:BuildDropdownList()
            for _, Element in next, ListInner:GetChildren() do
                if not Element:IsA('UIListLayout') then Element:Destroy(); end;
            end;

            local Count = 0;
            for Idx, Value in next, Dropdown.Values do
                Count = Count + 1;
                
                local Button = Library:Create('TextButton', {
                    BackgroundColor3 = Color3.new(1, 1, 1);
                    BackgroundTransparency = 1;
                    Size = UDim2.new(1, 0, 0, 28);
                    Text = '';
                    ZIndex = 23;
                    Parent = ListInner;
                    AutoButtonColor = false;
                });
                
                local Label = Library:CreateLabel({
                    Size = UDim2.new(1, -10, 1, 0);
                    Position = UDim2.fromOffset(10, 0);
                    TextSize = 14;
                    Text = Value;
                    TextXAlignment = Enum.TextXAlignment.Left;
                    ZIndex = 24;
                    Parent = Button;
                });
                
                -- Checkmark للاختيار المتعدد
                local Checkmark = Library:Create('Frame', {
                    BackgroundColor3 = Library.AccentColor;
                    BorderSizePixel = 0;
                    Size = UDim2.new(0, 0, 0, 0); -- يبدأ صفر ويكبر
                    Position = UDim2.new(0, 5, 0.5, -0);
                    AnchorPoint = Vector2.new(0, 0.5);
                    ZIndex = 24;
                    Parent = Button;
                    Visible = false;
                });
                Library:Create('UICorner', {CornerRadius = UDim.new(0, 2), Parent = Checkmark});

                local Selected = Info.Multi and Dropdown.Value[Value] or Dropdown.Value == Value;
                
                if Selected then
                    Checkmark.Visible = true
                    Checkmark.Size = UDim2.new(0, 4, 0.6, 0)
                    Label.TextColor3 = Library.AccentColor
                end

                Button.MouseEnter:Connect(function()
                    Library:SmoothTween(Button, {BackgroundTransparency = 0.95}, 0.2):Play()
                end)
                Button.MouseLeave:Connect(function()
                    Library:SmoothTween(Button, {BackgroundTransparency = 1}, 0.2):Play()
                end)

                Button.MouseButton1Click:Connect(function()
                    if Info.Multi then
                        Dropdown.Value[Value] = not Dropdown.Value[Value];
                        Selected = Dropdown.Value[Value];
                        if Selected then
                            Checkmark.Visible = true
                            Library:SmoothTween(Checkmark, {Size = UDim2.new(0, 4, 0.6, 0)}, 0.2):Play()
                            Library:SmoothTween(Label, {TextColor3 = Library.AccentColor}, 0.2):Play()
                        else
                            Library:SmoothTween(Checkmark, {Size = UDim2.new(0, 0, 0, 0)}, 0.2):Play()
                            task.wait(0.2)
                            Checkmark.Visible = false
                            Label.TextColor3 = Library.FontColor
                        end
                    else
                        Dropdown.Value = Value;
                        Dropdown:CloseDropdown();
                    end;
                    Dropdown:Display();
                    Library:SafeCallback(Dropdown.Callback, Dropdown.Value);
                    Library:SafeCallback(Dropdown.Changed, Dropdown.Value);
                end);
            end;

            ListInner.CanvasSize = UDim2.fromOffset(0, (Count * 28) + ((Count - 1) * 4));
            local Y = math.clamp(Count * 28, 0, MAX_DROPDOWN_ITEMS * 28) + 16;
            return Y;
        end;

        function Dropdown:OpenDropdown()
            local TargetHeight = Dropdown:BuildDropdownList();
            ListOuter.Visible = true;
            Library.OpenedFrames[ListOuter] = true;
            
            -- Animation فتح سلس
            Library:SmoothTween(ListOuter, {Size = UDim2.fromOffset(DropdownOuter.AbsoluteSize.X, TargetHeight)}, 0.3):Play()
            Library:SmoothTween(DropdownArrow, {Rotation = 180}, 0.3):Play();
        end;

        function Dropdown:CloseDropdown()
            Library:SmoothTween(ListOuter, {Size = UDim2.fromOffset(DropdownOuter.AbsoluteSize.X, 0)}, 0.2):Play()
            Library:SmoothTween(DropdownArrow, {Rotation = 0}, 0.2):Play();
            
            task.wait(0.2);
            ListOuter.Visible = false;
            Library.OpenedFrames[ListOuter] = nil;
        end;

        DropdownOuter.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and not Library:MouseIsOverOpenedFrame() then
                if ListOuter.Visible then Dropdown:CloseDropdown();
                else Dropdown:OpenDropdown(); end;
            end;
        end);

        Library:GiveSignal(InputService.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                local AbsPos, AbsSize = ListOuter.AbsolutePosition, ListOuter.AbsoluteSize;
                if Mouse.X < AbsPos.X or Mouse.X > AbsPos.X + AbsSize.X
                    or Mouse.Y < AbsPos.Y or Mouse.Y > AbsPos.Y + AbsSize.Y then
                    if ListOuter.Visible then Dropdown:CloseDropdown(); end;
                end;
            end;
        end));

        Dropdown:Display();
        Groupbox:AddBlank(Info.BlankSize or 8);
        Groupbox:Resize();
        Options[Idx] = Dropdown;
        return Dropdown;
    end;

