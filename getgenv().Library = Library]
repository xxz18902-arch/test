function Library:SetKeybindFilter(Filter)
    assert(Filter == 'Always' or Filter == 'On' or Filter == 'Off', 'Invalid keybind filter. Use "Always", "On", or "Off"');
    Library.KeybindFilter = Filter;
    
    for _, Option in next, Options do
